# =============================================================================
# XHS博主助手平台 — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Required
# Find these in your Supabase project: Settings > API
# -----------------------------------------------------------------------------

# Your Supabase project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — KEEP SECRET, server-side only
# Used by createAdminClient() to bypass RLS for trusted operations
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# AI API — 可选（作为系统级默认值）
# 如果不设置，每个用户需要在「设置」页面自行配置
# Find this at: https://console.anthropic.com/api-keys
# -----------------------------------------------------------------------------

# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Optional: App configuration
# -----------------------------------------------------------------------------

# Base URL for the application (used for redirects, webhooks)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Radar cache TTL in hours (default: 24)
# RADAR_CACHE_TTL_HOURS=24
